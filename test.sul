lowkey Main {
    aura main_character() {
        yap("Hello Teacher! This is native Assembly String Generation!");

        aura x = 10;
        aura y = 3;
        aura sum = x + y;
        yap(sum);

        aura max = 0;
        sus (x > y) {
            max = x;
        } cap {
            max = y;
        }
        yap(max);

        slay 0;
    }
}

